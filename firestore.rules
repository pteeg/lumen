rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // App data: Lumen interview guide (document path interviewGuides/{docId}, default id "main").
    // The web app uses Firebase Anonymous Auth so request.auth is set.
    // Console: Authentication → Sign-in methods → Anonymous → Enable.
    match /interviewGuides/{docId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else. Firestore ORs rules that match the same path, so
    // interviewGuides/* is still allowed above when signed in.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
