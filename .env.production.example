# Production Firebase — copy to `.env.production.local` (gitignored) and fill in.
# Used when you run `npm run build` or `vite build` (not `npm run dev`).
#
# Create a separate Firebase project for production (Firebase Console → Add project),
# add a Web app, then paste the config here. Deploy the same `firestore.rules` to that
# project (Authentication → Anonymous enabled, Firestore rules published).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Interview guide document id (default: main)
VITE_FIRESTORE_INTERVIEW_GUIDE_DOC_ID=main

# VITE_DISABLE_INTERVIEW_GUIDE_FIRESTORE=true
