# --- Development (`npm run dev`) ---
# Copy this file to `.env.local` and fill in your **dev** Firebase project
# (e.g. lumen-dev-2a5b9). Never commit `.env.local`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Interview guide — Firestore document interviewGuides/{id} (default id: main)
VITE_FIRESTORE_INTERVIEW_GUIDE_DOC_ID=main
# Set to true to skip Firestore sync (local state only)
# VITE_DISABLE_INTERVIEW_GUIDE_FIRESTORE=true
#
# Firestore: publish `firestore.rules` from this repo; enable Anonymous in Authentication.

# --- Production (`npm run build` / hosting) ---
# For a **separate production Firebase project**, copy `.env.production.example` to
# `.env.production.local` and add your production Web app config. Vite merges env files so
# production overrides `.env.local` when you build. On Vercel/Netlify, set the same
# `VITE_*` variables in the project dashboard instead of a file.
#
# Deploy rules to prod: `firebase deploy --only firestore:rules --project YOUR_PROD_PROJECT_ID`
# (or add a `prod` alias in `.firebaserc` and use `--project prod`).
